# 服务端口
PORT=3000

# JWT 密钥（生产环境务必使用随机长字符串）
JWT_SECRET=your-random-secret-here

# DeepSeek API（造句评分 & AI 对话）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat

# Freemium / Premium
# 多个会员码用英文逗号分隔；用户扫码付款后获得其中一个码并在前端兑换
PREMIUM_CODES=TOEFLIELTS-PREMIUM-2026,WORDS-GOLD-30
PREMIUM_DURATION_DAYS=365
PREMIUM_PRICE_LABEL=¥29 / 月

# 可填写本地或线上二维码图片地址，例如 /assets/payment-qr.png
PAYMENT_QR_IMAGE=
